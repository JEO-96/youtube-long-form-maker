  "intro": "도입부 (30초 이내)",
  "sections": [
    {
      "header": "섹션 제목",
      "body": "본문 내용 (나레이션 대본)",
      "visual_prompt": "이 섹션에 맞는 영상/이미지 프롬프트 (영문)",
      "estimated_duration_seconds": 120
    }
  ],
  "cta": "마무리 Call to Action",
